{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "66Claw",
    "version":  "1.0.4",
    "identifier":  "com.66claw.desktop",
    "build":  {
                  "beforeDevCommand":  "",
                  "beforeBuildCommand":  "bash src-tauri/scripts/stage-dist.sh",
                  "frontendDist":  "_dist/dist/control-ui"
              },
    "bundle":  {
                   "active":  true,
                   "targets":  [
                                   "nsis",
                                   "dmg",
                                   "app"
                               ],
                   "resources":  [
                                     "_dist/package.json",
                                     "_dist/dist",
                                     "_dist/node_modules",
                                     "_dist/extensions",
                                     "_dist/skills",
                                     "_dist/docs",
                                     "_dist/src",
                                     "_dist/node",
                                     "_dist/apps",
                                     "_dist/openclaw",
                                     "_dist/openclaw.cmd"
                                 ],
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.png",
                                "icons/icon.ico",
                                "icons/icon.icns"
                            ],
                   "windows":  {
                                   "nsis":  {
                                                "installerIcon":  "icons/icon.ico",
                                                "displayLanguageSelector":  true,
                                                "languages":  [
                                                                  "SimpChinese"
                                                              ],
                                                "installerHooks":  "nsis/hooks.nsh"
                                            }
                               },
                   "macOS":  {
                                 "minimumSystemVersion":  "13.0",
                                 "frameworks":  [

                                                ],
                                 "signingIdentity":  null,
                                 "entitlements":  null
                             }
               },
    "app":  {
                "windows":  [

                            ],
                "security":  {
                                 "csp":  "default-src \u0027self\u0027 http://127.0.0.1:19002 http://localhost:19002 http://127.0.0.1:19001 http://127.0.0.1:18789; script-src \u0027self\u0027 \u0027unsafe-eval\u0027 http://127.0.0.1:19002 http://localhost:19002; style-src \u0027self\u0027 \u0027unsafe-inline\u0027; font-src \u0027self\u0027 data:; img-src \u0027self\u0027 data: blob: https://*.anthropic.com; connect-src \u0027self\u0027 ws://localhost:19002 ws://127.0.0.1:19002 ws://localhost:19001 ws://127.0.0.1:19001 ws://localhost:18789 ws://127.0.0.1:18789 http://localhost:19002 http://127.0.0.1:19002 http://127.0.0.1:19001 http://127.0.0.1:18789 https://*.anthropic.com; media-src \u0027self\u0027 blob:; worker-src \u0027self\u0027 blob:"
                             }
            },
    "plugins":  {
                    "shell":  {
                                  "open":  "^https?://|^mailto:|^tel:"
                              }
                }
}