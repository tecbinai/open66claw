inux","macos","windows"],"isOfficial":false,"isNew":false,"toolCount":0,"installStatus":"not_installed","installable":true,"installMethod":"npm","sourceUrl":"https://github.com/ericyangpan/scan-qrcode-mcp","source":"modelscope","configHint":"需系统支持摄像头或图像文件读取权限","isVerified":false,"isHosted":false,"capabilities":["开发调试","自动化测试","设备扫码集成","IoT终端"]},{"serverId":"Althemy-HL_Query","friendlyName":"智能黄历助手","friendlyNameEn":"黄历查询【MCP&Agent挑战赛】","description":"融合传统农历、节气、宜忌与现代日程管理的AI黄历服务，支持吉时推荐与事件冲突检测。","descriptionEn":"","category":"other","tags":["黄历查询","农历节气","择吉服务","传统文化","日程规划","规则引擎","轻量AI"],"version":"0.0.0","npmPackage":"mcp-remote","securityScore":60,"requiresApiKey":false,"platforms":["linux","macos","windows"],"isOfficial":false,"isNew":false,"toolCount":0,"installStatus":"not_installed","installable":true,"installMethod":"npm","sourceUrl":"https://www.modelscope.cn/studios/Althemy/luner_info1","source":"modelscope","configHint":"纯前端计算逻辑，内置万年历算法与民俗知识库，零外部依赖","envSchema":{},"envRequired":[],"isVerified":false,"isHosted":true,"capabilities":["个人日程","婚庆策划","中医养生","文化教育"]},{"serverId":"lightyearsssr-rednote","friendlyName":"小红书媒体网关","friendlyNameEn":"小红书内容访问的MCP服务","description":"专为小红书生态设计的媒体资源统一接入网关，支持多云对象存储（阿里云OSS优先）、异步上传与CDN加速，符合国内合规要求。","descriptionEn":"小红书内容访问的MCP服务\nhttps://github.com/user-attachments\n\n# 项目概述\n本项目旨在提供一个微服务架构，用于处理小红书平台上的用户附件（如图片、视频等）的存储与访问。通过采用多云提供商(MCP)策略，我们能够确保数据的高可用性和可靠性。\n\n# 技术栈\n- **后端**: Spring Boot, MyBatis\n- **数据库**: MySQL\n- **对象存储**: 阿里云OSS, AWS S3\n- **消息队列**: RabbitMQ\n- **缓存**: Redis\n- **容器化**: Docker\n- **持续集成/持续部署(CI/CD)**: Jenkins\n- **版本控制**: Git (GitHub)\n\n# 快速开始\n## 环境准备\n确保你的开发环境已经安装了以下软件：\n- JDK 1.8 或更高版本\n- Maven 3.6.0 或更高版本\n- Docker 和 Docker Compose\n- MySQL 5.7 或更高版本\n- Redis 4.0 或更高版本\n- RabbitMQ 3.8 或更高版本\n\n## 构建项目\nbash\nmvn clean install\n\n\n## 启动服务\n使用Docker Compose来启动所有必要的服务。\nbash\ndocker-compose up -d\n\n\n## 访问API文档\nSwagger UI 可以用来查看和测试API接口。\n- 地址: `http://localhost:8080/swagger-ui.html`\n\n# 配置说明\n配置文件位于`src/main/resources/application.yml`中。根据实际部署环境调整相关参数，例如数据库连接信息、对象存储凭证等。\n\n# 贡献指南\n欢迎任何形式的贡献！请先阅读[贡献者指南](CONTRIBUTING.md)了解如何参与进来。\n\n# 许可证\n本项目采用MIT许可证发布，请参阅[LICENSE](LICENSE)获取更多信息。","category":"filesystem","tags":["小红书生态","媒体网关","多云存储","阿里云OSS","Spring Boot","微服务","国产化适配"],"version":"0.0.0","npmPackage":"lightyearsssr-rednote","securityScore":60,"requiresApiKey":false,"platforms":["linux","macos","windows"],"isOfficial":false,"isNew":false,"toolCount":0,"installStatus":"not_installed","installable":false,"installMethod":"none","sourceUrl":"https://github.com/iFurySt/RedNote-MCP","source":"modelscope","configHint":"已预置阿里云OSS SDK与国密SM4加密模块，AWS S3为可选降级方案","envSchema":{},"envRequired":[],"isVerified":false,"isHosted":false,"capabilities":["UGC内容分发","电商素材管理","合规化媒体中台"]},{"serverId":"@GongRzhe-REDIS-MCP-Server","friendlyName":"Redis智能操作器","friendlyNameEn":"Redis-MCP 交互服务器","description":"为LLM提供安全、受限的Redis读写能力，支持键模式匹配、哈希结构解析与TTL智能管理，适用于会话/缓存场景增强。","descriptionEn":"提供对Redis数据库的访问。此服务器通过一组标准化工具，使大型语言模型（LLM）能够与Redis键值存储进行交互。","category":"database","tags":["Redis","键值数据库","LLM数据库交互","缓存增强","MCP协议","会话管理","安全沙箱"],"version":"0.0.0","npmPackage":"@gongrzhe/server-redis-mcp@1.0.0","securityScore":60,"requiresApiKey":false,"platforms":["linux","macos","windows"],"isOfficial":false,"isNew":false,"toolCount":0,"installStatus":"not_installed","installable":true,"installMethod":"npm","sourceUrl":"https://github.com/GongRzhe/REDIS-MCP-Server","source":"modelscope","configHint":"默认禁用危险命令（FLUSHDB/EVAL），支持白名单机制与连接池隔离","envSchema":{},"envRequired":[],"isVerified":false,"isHosted":false,"capabilities":["AI会话缓存","实时特征存储","LLM状态持久化"]},{"serverId":"@tadasant-mcp-server-ssh-rails-runner","friendlyName":"Rails智控台","friendlyNameEn":"Rails SSH 控制台运行器","description":"通过SSH安全接入生产Rails环境，支持自然语言解析执行rails console命令，兼顾审计、权限隔离与变更预演。","descriptionEn":"启用通过 SSH 在部署的 Rails 环境中进行安全的远程执行 Rails 控制台命令，适用于只读操作、变更规划以及执行已批准的更改。","category":"ai","tags":["Rails运维","SSH安全执行","生产环境管控","Ruby on Rails","DevOps工具","命令审