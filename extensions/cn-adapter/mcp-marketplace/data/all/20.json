:"0.0.0","npmPackage":"mcp-echarts","securityScore":60,"requiresApiKey":false,"platforms":["linux","macos","windows"],"isOfficial":false,"isNew":false,"toolCount":0,"installStatus":"not_installed","installable":true,"installMethod":"npm","sourceUrl":"https://github.com/hustcc/mcp-echarts","source":"modelscope","configHint":"需本地安装ECharts JS库或通过CDN加载","isVerified":false,"isHosted":true,"capabilities":["BI看板","AI报告生成","前端图表自动化","教学演示"]},{"serverId":"JupiterC-wechat_oa_mcp","friendlyName":"微信公众号智管","friendlyNameEn":"微信公众号API-MCP-Server","description":"基于MCP协议的微信公众号AI运营中枢，支持图文/HTML草稿创建、定时发布、媒体托管与Token安全调度。","descriptionEn":"# 微信公众号 MCP 服务简介\n\n## 服务概述\n\n微信公众号MCP（模型控制协议）服务是一个专为通过AI自动化简化微信公众号管理而设计的专业工具。该服务为在微信公众号上创建、发布和管理内容提供了标准化接口，消除了常规发布任务中的手动干预需求。\n\n## 核心功能\n\n- **访问令牌管理**：安全处理认证凭证\n- **内容创建**：支持文本、图片和HTML格式的富媒体内容草稿的程序化创建\n- **发布自动化**：定时或按需将内容发布到微信公众号\n- **资源管理**：高效处理媒体资源和草稿内容\n- **MCP兼容性**：通过模型控制协议标准与AI代理和LLM系统无缝集成\n\n## 技术实现\n\n基于FastMCP框架构建，该服务暴露了一组可由AI系统调用的标准化工具，用于在微信公众号上执行操作。服务处理与微信API的所有通信，透明地管理认证、速率限制和错误处理。\n\n## 使用场景\n\n- 从AI生成内容自动发布内容\n- 定时发布定期更新或通讯\n- 与内容管理系统集成，实现跨平台发布\n- 使AI助手能够管理社交媒体存在\n\n## 集成方式\n\n该服务可以与任何支持MCP协议的系统集成，包括Cursor、ModelScope和自定义MCP客户端。它可以在本地部署或在服务器上部署以进行集中访问。 ","category":"network","tags":["微信生态","AI运营","内容自动化","OAuth2管理","MCP集成","企业号管理","定时任务"],"version":"0.0.0","npmPackage":"JupiterC-wechat_oa_mcp","securityScore":60,"requiresApiKey":false,"platforms":["linux","macos","windows"],"isOfficial":false,"isNew":false,"toolCount":0,"installStatus":"not_installed","installable":true,"installMethod":"pypi","sourceUrl":"https://modelscope.cn/mcp/servers/JupiterC-wechat_oa_mcp","source":"modelscope","configHint":"需部署在中国大陆境内服务器以保障微信API调用稳定性","isVerified":false,"isHosted":false,"capabilities":["新媒体运营","政务公众号","企业资讯推送","AI内容分发"]},{"serverId":"Karl66-edgeone-pages-mcp","friendlyName":"EdgeOne静态托管","friendlyNameEn":"Karl66-edgeone-pages-mcp","description":"一键部署HTML/ZIP至腾讯云EdgeOne Pages，自动生成CDN加速URL，支持流式HTTP与stdio双协议接入。","descriptionEn":"一个用于将HTML内容、文件夹和zip文件部署到EdgeOne Pages并获取公开访问URL的MCP服务。它支持stdio MCP服务器和可流式HTTP MCP服务器配置。","category":"filesystem","tags":["静态网站","CDN托管","边缘计算","腾讯云","MCP部署","前端发布","自动化上线"],"version":"0.0.0","npmPackage":"edgeone-pages-mcp","securityScore":60,"requiresApiKey":false,"platforms":["linux","macos","windows"],"isOfficial":false,"isNew":false,"toolCount":0,"installStatus":"not_installed","installable":true,"installMethod":"npm","sourceUrl":"https://github.com/TencentEdgeOne/edgeone-pages-mcp","source":"modelscope","configHint":"需提前配置Tencent Cloud密钥（CAM权限：QcloudEdgeOneFullAccess）","envSchema":{"EDGEONE_PAGES_API_TOKEN":{"description":"","type":"string"},"EDGEONE_PAGES_PROJECT_NAME":{"description":"","type":"string"}},"envRequired":["EDGEONE_PAGES_API_TOKEN"],"isVerified":false,"isHosted":true,"capabilities":["前端CI/CD","文档站点发布","营销页快速上线","AI生成网页托管"]},{"serverId":"@xiangma9712-mysql-mcp-server","friendlyName":"MySQL智查","friendlyNameEn":"MySQL MCP服务","description":"面向AI代理的MySQL安全交互服务，支持SQL执行、结构探测与Docker沙箱验证，兼顾灵活性与防误操作机制。","descriptionEn":"通过JSON命令启用与MySQL数据库的交互，支持只读查询、写查询的测试执行以及通过Docker进行的表信息检索。","category":"database","tags":["数据库查询","SQL执行","Docker沙箱","结构分析","MCP数据工具","只读保护","开发调试"],"version":"0.0.0","npmPackage":"docker:ghcr.io/xiangma9712/mcp/mysql","securityScore":60,"requiresApiKey":false,"platforms":["linux","macos","windows"],"isOfficial":false,"isNew":false,"toolCount":0,"installStatus":"not_installed","installable":true,"installMethod":"npm","sourceUrl":"https://github.com/xiangma9712/mysql-mcp-server","source":"modelscope","configHint":"生产环境建议启用SSL连接及IP白名单；Docker模式需宿主机支持Docker Engine","envSchema":{"MYSQL_HOST":{"description":"Hostname to access MySQL server. Use host.docker.internal to access host services from Docker container.","type":"string"},"MYSQL_PASSWORD":{"description":"MySQL password","type":"string"},"MYSQL_PORT":{"description":"MySQL server port","type":"string"},"MYSQL_USER":{"description":"MySQL username","type":"string"}},"envRequired":["MYSQL_HOST","MYSQL_PORT","MYSQL