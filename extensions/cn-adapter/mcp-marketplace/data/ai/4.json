e=marketMcpDetail","source":"modelscope","configHint":"需企业管理员在钉钉开放平台完成应用授权并配置回调域名","envSchema":{},"envRequired":[],"sseUrl":"https://mcp.dingtalk.com/#/detail?mcpId=2400&detailType=marketMcpDetail","isVerified":false,"isHosted":true,"capabilities":["员工信息查询","部门架构同步","OA系统对接","入职流程自动化"]},{"serverId":"@istarwyh-MCP-Advisor","friendlyName":"MCP智导员","friendlyNameEn":"MCP-Advisor","description":"基于本地知识库的MCP服务发现引擎，支持自然语言查询匹配功能，无需联网即可推荐适配工具。","descriptionEn":"MCP Advisor 是一个发现和推荐服务，帮助 AI 助手使用自然语言查询探索 Model Context Protocol (MCP) 服务器。它让用户更容易找到并利用适合特定任务的 MCP 工具。","category":"ai","tags":["服务发现","自然语言理解","本地知识库","AI助手增强","MCP生态导航"],"version":"0.0.0","npmPackage":"@xiaohui-wang/mcpadvisor","securityScore":60,"requiresApiKey":false,"platforms":["linux","macos","windows"],"isOfficial":false,"isNew":false,"toolCount":0,"installStatus":"not_installed","installable":true,"installMethod":"npm","sourceUrl":"https://github.com/istarwyh/mcpadvisor","source":"modelscope","configHint":"内置中文MCP服务元数据索引，支持增量更新","envSchema":{},"envRequired":[],"isVerified":false,"isHosted":true,"capabilities":["AI工具链搭建","MCP服务治理","低代码集成导航"]}]